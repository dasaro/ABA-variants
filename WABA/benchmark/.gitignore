# WABA Benchmark .gitignore
# Tracks code, ignores artifacts

# ============================================================
# ARTIFACTS (generated/experimental data)
# ============================================================

# Plans (experimental design)
plans/**
!plans/.gitkeep

# Frameworks (generated test instances)
frameworks/**
!frameworks/.gitkeep

# Results (benchmark outputs)
results/**
!results/.gitkeep

# Analysis (processed results)
analysis/**
!analysis/.gitkeep

# Logs (execution logs)
logs/**
!logs/.gitkeep

# Archive (old experiments)
archive/**
!archive/.gitkeep
!archive/README.md

# ============================================================
# PYTHON ARTIFACTS
# ============================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Virtual environments
venv/
ENV/
env/
.venv

# ============================================================
# MACOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride

# ============================================================
# IDE / EDITORS
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# TEMPORARY FILES
# ============================================================
*.tmp
*.bak
*.log~
