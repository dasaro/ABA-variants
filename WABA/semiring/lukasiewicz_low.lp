%% Dual Łukasiewicz semiring with lower-is-better orientation.
%% Generated by scripts/generate_semiring_variants.py.
%%
%% Finite domain: [0,K], K given by luk_k (default 100).
%% Disjunction/alternative support: max(0, sum - K*(n-1))
%% Conjunction/rule body: min(K, sum)
%% Interpretation: lower is better.

#const luk_k = 100.
active_semiring(lukasiewicz_low).
#include "../defaults/base.lp".

semiring_default_weight(legacy,#sup).
semiring_default_weight(aba,#sup).
semiring_default_weight(neutral,0).

supported_with_weight(X,W) :- assumption(X), in(X), weight(X,W), not head(_,X).
supported_with_weight(X,W) :- assumption(X), in(X), not weight(X,_), not head(_,X), default_assumption_weight(W).

default_weight_is_sup :- default_assumption_weight(#sup).
finite_default_weight(V) :- default_assumption_weight(V), V != #sup, V != #inf.

body_has_sup_weight(R) :- body(R,B), supported_with_weight(B,#sup).
body_has_inf_weight(R) :- body(R,B), supported_with_weight(B,#inf).

rule_derivation_weight(R,X,#sup) :-
    head(R,X),
    supported(X),
    body(R,_),
    triggered_by_in(R),
    body_has_sup_weight(R).

rule_derivation_weight(R,X,#inf) :-
    head(R,X),
    supported(X),
    body(R,_),
    triggered_by_in(R),
    not body_has_sup_weight(R),
    body_has_inf_weight(R).

rule_derivation_weight(R,X,W) :-
    head(R,X),
    supported(X),
    body(R,_),
    triggered_by_in(R),
    not body_has_sup_weight(R),
    not body_has_inf_weight(R),
    S = #sum{ V,B : body(R,B), supported_with_weight(B,V) },
    W = #min{ luk_k; S }.

rule_derivation_weight(R,X,luk_k) :-
    head(R,X),
    supported(X),
    not body(R,_).

finite_rule_derivation_weight(R,X,V) :-
    rule_derivation_weight(R,X,V),
    V != #sup,
    V != #inf.

finite_explicit_weight(X,V) :-
    weight(X,V),
    V != #sup,
    V != #inf.

has_inf_support_term(X) :- rule_derivation_weight(_,X,#inf).
has_inf_support_term(X) :- weight(X,#inf).

supported_with_weight(X,#sup) :-
    supported(X),
    head(_,X),
    not assumption(X),
    rule_derivation_weight(_,X,#sup).

supported_with_weight(X,#sup) :-
    supported(X),
    head(_,X),
    not assumption(X),
    weight(X,#sup).

supported_with_weight(X,0) :-
    supported(X),
    head(_,X),
    not assumption(X),
    not rule_derivation_weight(_,X,#sup),
    not weight(X,#sup),
    has_inf_support_term(X).

supported_with_weight(X,W) :-
    supported(X),
    head(_,X),
    not assumption(X),
    not rule_derivation_weight(_,X,#sup),
    not weight(X,#sup),
    not has_inf_support_term(X),
    N = #sum{ 1,R : finite_rule_derivation_weight(R,X,_) ;
              1,V : finite_explicit_weight(X,V) },
    S = #sum{ V,R : finite_rule_derivation_weight(R,X,V) ;
              V,V : finite_explicit_weight(X,V) },
    W = #max{ 0; S - luk_k*(N-1) }.

supported_with_weight(X,#sup) :-
    assumption(X),
    supported(X),
    head(_,X),
    not weight(X,_),
    default_weight_is_sup.

supported_with_weight(X,W) :-
    assumption(X),
    supported(X),
    head(_,X),
    not weight(X,_),
    not rule_derivation_weight(_,X,#sup),
    finite_default_weight(D),
    not has_inf_support_term(X),
    N = #sum{ 1,R : finite_rule_derivation_weight(R,X,_) ;
              1 : true },
    S = #sum{ V,R : finite_rule_derivation_weight(R,X,V) ;
              D : true },
    W = #max{ 0; S - luk_k*(N-1) }.

supported_with_weight(X,#sup) :-
    assumption(X),
    supported(X),
    head(_,X),
    weight(X,_),
    rule_derivation_weight(_,X,#sup).

supported_with_weight(X,#sup) :-
    assumption(X),
    supported(X),
    head(_,X),
    weight(X,#sup).

supported_with_weight(X,0) :-
    assumption(X),
    supported(X),
    head(_,X),
    weight(X,_),
    not rule_derivation_weight(_,X,#sup),
    not weight(X,#sup),
    has_inf_support_term(X).

supported_with_weight(X,W) :-
    assumption(X),
    supported(X),
    head(_,X),
    weight(X,_),
    not rule_derivation_weight(_,X,#sup),
    not weight(X,#sup),
    not has_inf_support_term(X),
    N = #sum{ 1,R : finite_rule_derivation_weight(R,X,_) ;
              1,V : finite_explicit_weight(X,V) },
    S = #sum{ V,R : finite_rule_derivation_weight(R,X,V) ;
              V,V : finite_explicit_weight(X,V) },
    W = #max{ 0; S - luk_k*(N-1) }.

undefeated_weight(X,W) :- assumption(X), not defeated(X), not weight(X,_), not head(_,X), default_assumption_weight(W).
undefeated_weight(X,W) :- assumption(X), not defeated(X), weight(X,W), not head(_,X).

undefeated_body_has_sup(R) :- body(R,B), undefeated_weight(B,#sup).
undefeated_body_has_inf(R) :- body(R,B), undefeated_weight(B,#inf).

undefeated_rule_weight(R,X,#sup) :-
    head(R,X),
    derived_from_undefeated(X),
    body(R,_),
    triggered_by_undefeated(R),
    undefeated_body_has_sup(R).

undefeated_rule_weight(R,X,#inf) :-
    head(R,X),
    derived_from_undefeated(X),
    body(R,_),
    triggered_by_undefeated(R),
    not undefeated_body_has_sup(R),
    undefeated_body_has_inf(R).

undefeated_rule_weight(R,X,W) :-
    head(R,X),
    derived_from_undefeated(X),
    body(R,_),
    triggered_by_undefeated(R),
    not undefeated_body_has_sup(R),
    not undefeated_body_has_inf(R),
    S = #sum{ V,B : body(R,B), undefeated_weight(B,V) },
    W = #min{ luk_k; S }.

undefeated_rule_weight(R,X,luk_k) :-
    head(R,X),
    derived_from_undefeated(X),
    not body(R,_).

finite_undefeated_rule_weight(R,X,V) :-
    undefeated_rule_weight(R,X,V),
    V != #sup,
    V != #inf.

finite_undefeated_explicit_weight(X,V) :-
    weight(X,V),
    V != #sup,
    V != #inf.

has_inf_undefeated_term(X) :- undefeated_rule_weight(_,X,#inf).
has_inf_undefeated_term(X) :- weight(X,#inf).

undefeated_weight(X,#sup) :-
    derived_from_undefeated(X),
    head(_,X),
    not assumption(X),
    undefeated_rule_weight(_,X,#sup).

undefeated_weight(X,#sup) :-
    derived_from_undefeated(X),
    head(_,X),
    not assumption(X),
    weight(X,#sup).

undefeated_weight(X,0) :-
    derived_from_undefeated(X),
    head(_,X),
    not assumption(X),
    not undefeated_rule_weight(_,X,#sup),
    not weight(X,#sup),
    has_inf_undefeated_term(X).

undefeated_weight(X,W) :-
    derived_from_undefeated(X),
    head(_,X),
    not assumption(X),
    not undefeated_rule_weight(_,X,#sup),
    not weight(X,#sup),
    not has_inf_undefeated_term(X),
    N = #sum{ 1,R : finite_undefeated_rule_weight(R,X,_) ;
              1,V : finite_undefeated_explicit_weight(X,V) },
    S = #sum{ V,R : finite_undefeated_rule_weight(R,X,V) ;
              V,V : finite_undefeated_explicit_weight(X,V) },
    W = #max{ 0; S - luk_k*(N-1) }.

undefeated_weight(X,#sup) :-
    assumption(X),
    not defeated(X),
    derived_from_undefeated(X),
    head(_,X),
    not weight(X,_),
    default_weight_is_sup.

undefeated_weight(X,W) :-
    assumption(X),
    not defeated(X),
    derived_from_undefeated(X),
    head(_,X),
    not weight(X,_),
    not undefeated_rule_weight(_,X,#sup),
    finite_default_weight(D),
    not has_inf_undefeated_term(X),
    N = #sum{ 1,R : finite_undefeated_rule_weight(R,X,_) ;
              1 : true },
    S = #sum{ V,R : finite_undefeated_rule_weight(R,X,V) ;
              D : true },
    W = #max{ 0; S - luk_k*(N-1) }.

undefeated_weight(X,#sup) :-
    assumption(X),
    not defeated(X),
    derived_from_undefeated(X),
    head(_,X),
    weight(X,_),
    undefeated_rule_weight(_,X,#sup).

undefeated_weight(X,#sup) :-
    assumption(X),
    not defeated(X),
    derived_from_undefeated(X),
    head(_,X),
    weight(X,#sup).

undefeated_weight(X,0) :-
    assumption(X),
    not defeated(X),
    derived_from_undefeated(X),
    head(_,X),
    weight(X,_),
    not undefeated_rule_weight(_,X,#sup),
    not weight(X,#sup),
    has_inf_undefeated_term(X).

undefeated_weight(X,W) :-
    assumption(X),
    not defeated(X),
    derived_from_undefeated(X),
    head(_,X),
    weight(X,_),
    not undefeated_rule_weight(_,X,#sup),
    not weight(X,#sup),
    not has_inf_undefeated_term(X),
    N = #sum{ 1,R : finite_undefeated_rule_weight(R,X,_) ;
              1,V : finite_undefeated_explicit_weight(X,V) },
    S = #sum{ V,R : finite_undefeated_rule_weight(R,X,V) ;
              V,V : finite_undefeated_explicit_weight(X,V) },
    W = #max{ 0; S - luk_k*(N-1) }.

unaffordable_attack(W,B) :- undefeated_weight(_,W), budget(B), B = 0, W != #inf.
unaffordable_attack(W,B) :- undefeated_weight(_,W), budget(B), B != 0, W > B.
