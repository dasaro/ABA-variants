# Test and analysis results
test_results/
*_results/
*_output/
*.out

# Benchmark artifacts (ignore generated data, but track source code)
benchmark/results*/
benchmark/analysis*/
benchmark/frameworks*/
benchmark/test_frameworks*/
benchmark/*.jsonl
benchmark/*.csv
benchmark/*.log
benchmark/*.meta.json
benchmark/TOPOLOGY_DIAGRAMS/
*_ANALYSIS.md
*_REPORT.md
*.png

# But allow benchmark source code to be tracked
!benchmark/**/*.py
!benchmark/**/*.md
!benchmark/**/*.sh
!benchmark/README.md
!benchmark/SMOKE_TEST.md
!benchmark/EXPERIMENTAL_DESIGN.md

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Temporary and backup files
*.tmp
*.log
*.bak
*~
